<?xml version="1.0" encoding="utf-8"?>
<!-- Small native ad card — white surface, app-rounded corners, faint brand border.
     NOTE: no elevation here (would hide the AdChoices icon — see native_ads_android_setup.md §4). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/native_ad_surface" />
    <corners android:radius="12dp" />
    <stroke android:width="1dp" android:color="@color/native_ad_stroke" />
</shape>
