<?xml version="1.0" encoding="utf-8"?>
<!-- Small native ad — horizontal pill (icon · text · CTA), themed to match the
     FinWise app (StackSansHeadline font, brand colors from colors.xml).
     Root MUST be NativeAdView. No elevation anywhere → AdChoices icon stays visible. -->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/native_ad_card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/native_ad_icon_bg">

            <ImageView
                android:id="@+id/ad_app_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/ad_attribution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/native_ad_attribution_bg"
                    android:fontFamily="@font/stack_sans_bold"
                    android:paddingStart="6dp"
                    android:paddingTop="1dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="1dp"
                    android:text="Ad"
                    android:textColor="@color/native_ad_badge_text"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/stack_sans_bold"
                    android:maxLines="1"
                    android:textColor="@color/native_ad_text"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:fontFamily="@font/stack_sans_regular"
                android:maxLines="2"
                android:textColor="@color/native_ad_body"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/ad_call_to_action"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/native_ad_cta_bg"
            android:fontFamily="@font/stack_sans_semibold"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="92dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textAllCaps="false"
            android:textColor="@color/native_ad_cta_text"
            android:textSize="15sp" />
    </LinearLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
