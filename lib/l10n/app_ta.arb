  "@loanCreditCardStep4Subtitle": {},
  "tipsCreditFactor1DoItem": "ஒவ்வொரு முறையும் அனைத்து பில்களையும் சரியான நேரத்தில் செலுத்துங்கள்",
  "@tipsCreditFactor1DoItem": {},
  "tipsCreditFactor1DontItem": "ஒரு கட்டணத்தை கூட தவறவிடுவது குறிப்பிடத்தக்க வகையில் பாதிக்கப்படுகிறது",
  "@tipsCreditFactor1DontItem": {},
  "tipsCreditFactor2DoItem": "உங்கள் கிரெடிட் வரம்பில் 30% க்கும் குறைவாக வைத்திருக்கவும்",
  "@tipsCreditFactor2DoItem": {},
  "tipsCreditFactor2DontItem": "கார்டுகளை அதிகப்படுத்துவது நிதி அழுத்தத்தைக் குறிக்கிறது",
  "@tipsCreditFactor2DontItem": {},
  "tipsCreditFactor3DoItem": "பயன்படுத்தப்படாவிட்டாலும் பழைய கணக்குகளைத் திறந்து வைத்திருங்கள்",
  "@tipsCreditFactor3DoItem": {},
  "tipsCreditFactor3DontItem": "பழைய அட்டையை மூடுவது சராசரி வயதைக் குறைக்கிறது",
  "@tipsCreditFactor3DontItem": {},
  "tipsCreditFactor4DoItem": "ஒரு கலவை: அட்டைகள், கடன்கள், அடமானங்கள்",
  "@tipsCreditFactor4DoItem": {},
  "tipsCreditFactor4DontItem": "ஒரே ஒரு வகை கிரெடிட் வரம்புகள் மதிப்பெண்",
  "@tipsCreditFactor4DontItem": {},
  "tipsCreditFactor5DoItem": "தேவைப்படும் போது மட்டும் கடன் பெற விண்ணப்பிக்கவும்",
  "@tipsCreditFactor5DoItem": {},
  "tipsCreditFactor5DontItem": "குறுகிய காலத்தில் பல பயன்பாடுகள்",
  "@tipsCreditFactor5DontItem": {},
  "tipsPayDebtBullet1": "வட்டி விகிதம் 12%க்கு மேல் (கிரெடிட் கார்டுகள், தனிநபர் கடன்கள்)",
  "@tipsPayDebtBullet1": {},
  "tipsPayDebtBullet2": "நீங்கள் கிரெடிட் கார்டுகளில் குறைந்தபட்ச நிலுவைத் தொகையை மட்டுமே செலுத்துகிறீர்கள்",
  "@tipsPayDebtBullet2": {},
  "tipsPayDebtBullet3": "கடன் மன அழுத்தத்தை ஏற்படுத்துகிறது அல்லது கிரெடிட் ஸ்கோரை பாதிக்கிறது",
  "@tipsPayDebtBullet3": {},
  "tipsPayDebtBullet4": "இன்னும் அவசரகால நிதி இல்லை",
  "@tipsPayDebtBullet4": {},
  "tipsInvestBullet1": "வட்டி விகிதம் 10% க்கும் குறைவாக உள்ளது (வீட்டுக் கடன், கல்விக் கடன்)",
  "@tipsInvestBullet1": {},
  "tipsInvestBullet2": "உங்களிடம் ஏற்கனவே 6 மாத அவசர நிதி உள்ளது",
  "@tipsInvestBullet2": {},
  "tipsInvestBullet3": "பணியளிப்பவர் ஓய்வூதிய பங்களிப்புகளுடன் பொருந்துகிறார் (இலவச பணம்)",
  "@tipsInvestBullet3": {},
  "tipsInvestBullet4": "நீண்ட முதலீட்டு எல்லை (15+ ஆண்டுகள்)",
  "@tipsInvestBullet4": {},
  "tipsAge20sTip1": "அவசர நிதியை உருவாக்கவும் (3-6 மாத செலவுகள்)",
  "@tipsAge20sTip1": {},
  "tipsAge20sTip2": "ஆரம்பத்தில் முதலீடு செய்யத் தொடங்குங்கள்-சிறிய அளவு கூட்டும் கூட",
  "@tipsAge20sTip2": {},
  "tipsAge20sTip3": "கிரெடிட் கார்டு கடனை எல்லா விலையிலும் தவிர்க்கவும்",
  "@tipsAge20sTip3": {},
  "tipsAge20sTip4": "சார்புடையவர்கள் இருந்தால் கால ஆயுள் காப்பீட்டைப் பெறுங்கள்",
  "@tipsAge20sTip4": {},
  "tipsAge30sTip1": "அவசரகால நிதியை 6-12 மாதங்களுக்கு அதிகரிக்கவும்",
  "@tipsAge30sTip1": {},
  "tipsAge30sTip2": "அதிகபட்ச ஓய்வூதிய பங்களிப்புகள்",
  "@tipsAge30sTip2": {},
  "tipsAge30sTip3": "பொருந்தினால் குழந்தை கல்வி நிதியைத் தொடங்கவும்",
  "@tipsAge30sTip3": {},
  "tipsAge30sTip4": "போதுமான ஆயுள் மற்றும் சுகாதார காப்பீடு வாங்கவும்",
  "@tipsAge30sTip4": {},
  "tipsAge40sTip1": "ஓய்வூதிய சேமிப்புகளை தீவிரமாக துரிதப்படுத்துங்கள்",
  "@tipsAge40sTip1": {},
  "tipsAge40sTip2": "அதிக வட்டிக்குக் கடன்களை முழுமையாகச் செலுத்துங்கள்",
  "@tipsAge40sTip2": {},
  "tipsAge40sTip3": "காப்பீட்டுத் தொகையை மதிப்பாய்வு செய்து அதிகரிக்கவும்",
  "@tipsAge40sTip3": {},
  "tipsAge40sTip4": "எஸ்டேட் திட்டமிடல் மற்றும் உருவாக்கம்",
  "@tipsAge40sTip4": {},
  "tipsAge50sTip1": "குறைந்த ஆபத்து, வருமானத்தை மையமாகக் கொண்ட முதலீடுகளுக்கு மாறவும்",
  "@tipsAge50sTip1": {},
  "tipsAge50sTip2": "ஓய்வுக்கு முன் செலுத்தப்பட்ட அனைத்து கடன்களையும் உறுதிப்படுத்தவும்",
  "@tipsAge50sTip2": {},
  "tipsAge50sTip3": "ஓய்வூதிய பங்களிப்புகளை அதிகரிக்கவும் (கேட்-அப் அனுமதிக்கப்படுகிறது)",
  "@tipsAge50sTip3": {},
  "tipsAge50sTip4": "சுகாதார மற்றும் நீண்ட கால பராமரிப்பு செலவுகளை திட்டமிடுங்கள்",
